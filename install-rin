#!/usr/bin/env bash
set -euo pipefail

APP="rin"
REPO_OWNER="MenterMasterBot"
REPO_NAME="Hello-World"
RAW_BASE="https://raw.githubusercontent.com/${REPO_OWNER}/${REPO_NAME}/main"
INSTALL_DIR="${INSTALL_DIR:-$HOME/.rin/bin}"
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
RED='\033[0;31m'
BOLD_RED='\033[1;31m'
DIM_RED='\033[2;31m'
NC='\033[0m'

# ──────────────────────────────────────────────
# UTILITY FUNCTIONS
# ──────────────────────────────────────────────

info()    { echo -e "${RED}• $*${NC}"; }
muted()   { echo -e "${DIM_RED}$*${NC}"; }
warn()    { echo -e "${RED}⚠ $*${NC}" >&2; }
error()   { echo -e "${RED}✖ $*${NC}" >&2; }
die()     { error "$1"; exit "${2:-1}"; }
header()  { echo -e "\n${BOLD_RED}── $* ──${NC}"; }

cleanup() {
  local tmp_dir="${TMPDIR:-/tmp}/rin_install_$$"
  rm -rf "$tmp_dir" 2>/dev/null || true
}
trap cleanup EXIT INT TERM HUP

# ──────────────────────────────────────────────
# CONFIG
# ──────────────────────────────────────────────

requested_version="${VERSION:-}"
no_modify_path=false
no_obedience=false
no_token_limit=false
binary_path=""
force=false
do_uninstall=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      cat <<EOF
${BOLD_RED}RIN — HACKER RIN CYBER Edition${NC}

Usage: curl -fsSL https://${REPO_OWNER}.github.io/${REPO_NAME}/rin | bash

${BOLD_RED}Options:${NC}
  -h, --help               Display this help message
  -b, --binary <path>      Install from a local binary instead of downloading
  -f, --force              Overwrite existing config files
      --uninstall          Remove RIN binary and config files
      --no-modify-path     Don't modify shell config files
      --no-obedience       Skip obedience (never-refuse) config
      --no-token-limit     Skip unlimited token limits in config
EOF
      exit 0 ;;
    -b|--binary)
      [[ -n "${2:-}" ]] || die "--binary requires a path argument"
      binary_path="$2"; shift 2 ;;
    -f|--force) force=true; shift ;;
    --uninstall) do_uninstall=true; shift ;;
    --no-modify-path) no_modify_path=true; shift ;;
    --no-obedience) no_obedience=true; shift ;;
    --no-token-limit) no_token_limit=true; shift ;;
    *) warn "Unknown option '$1' (ignored)"; shift ;;
  esac
done

# ──────────────────────────────────────────────
# UNINSTALL
# ──────────────────────────────────────────────

uninstall() {
  header "Uninstalling RIN"

  local bin="$INSTALL_DIR/rin"
  if [[ -f "$bin" ]]; then
    echo -n "  Remove binary at ${bin}? [y/N] "
    read -r ans
    if [[ "$ans" =~ ^[yY] ]]; then
      rm -f "$bin"
      info "Binary removed"
    fi
  else
    muted "  No binary found at ${bin}"
  fi

  local symlink="$HOME/.local/bin/rin"
  if [[ -L "$symlink" ]]; then
    rm -f "$symlink"
    info "Symlink removed: ${symlink}"
  fi

  rmdir "$INSTALL_DIR" 2>/dev/null || true

  echo ""
  info "Uninstall complete."
  exit 0
}

[[ "$do_uninstall" == "true" ]] && uninstall

# ──────────────────────────────────────────────
# PLATFORM DETECTION
# ──────────────────────────────────────────────

detect_platform() {
  raw_os=$(uname -s)
  arch=$(uname -m)
  [[ "$arch" == "x86_64" ]] && arch="x64"
  [[ "$arch" == "aarch64" ]] && arch="arm64"

  os="unknown"
  case "$raw_os" in
    Linux*)  os="linux" ;;
    Darwin*) os="darwin" ;;
    *) die "Unsupported OS: $raw_os" ;;
  esac

  TARGET="${os}-${arch}"
  ARCHIVE="rin-${TARGET}.tar.gz"
  # Only linux-x64 is currently built
  if [[ "$TARGET" != "linux-x64" ]]; then
    # Try anyway — if the file exists, great; if not, we'll fail gracefully
    warn "No prebuilt binary for ${TARGET} — attempting download anyway"
  fi
}

detect_platform

# ──────────────────────────────────────────────
# DOWNLOAD & INSTALL
# ──────────────────────────────────────────────

download_and_install() {
  header "Downloading RIN"

  local tmp_dir="${TMPDIR:-/tmp}/rin_install_$$"
  mkdir -p "$tmp_dir"

  local archive_url="${RAW_BASE}/${ARCHIVE}"
  local archive_path="$tmp_dir/$ARCHIVE"

  info "Downloading: ${archive_url}"
  curl -fL -o "$archive_path" "$archive_url" || die "Download failed — binary for ${TARGET} may not be available yet"

  local file_size
  file_size=$(stat -c%s "$archive_path" 2>/dev/null || stat -f%z "$archive_path" 2>/dev/null || echo 0)
  ((file_size > 0)) || die "Downloaded file is empty"

  header "Extracting"
  tar -xzf "$archive_path" -C "$tmp_dir"

  [[ -f "$tmp_dir/rin" ]] || die "Extracted archive does not contain 'rin' binary"

  mkdir -p "$INSTALL_DIR"
  mv "$tmp_dir/rin" "$INSTALL_DIR/rin"
  chmod 755 "${INSTALL_DIR}/rin"

  # Symlink to ~/.local/bin for immediate PATH access
  if [[ ":$PATH:" == *":$HOME/.local/bin:"* ]]; then
    mkdir -p "$HOME/.local/bin"
    ln -sf "$INSTALL_DIR/rin" "$HOME/.local/bin/rin"
  fi

  # Verify
  local version_output
  version_output=$("${INSTALL_DIR}/rin" --version 2>&1 || true)
  if [[ -n "$version_output" ]]; then
    muted "  Version: ${version_output}"
  fi
  info "Binary installed: ${INSTALL_DIR}/rin"

  rm -rf "$tmp_dir"
}

install_from_binary() {
  header "Installing from local binary"
  [[ -f "$binary_path" ]] || die "Binary not found at ${binary_path}"
  mkdir -p "$INSTALL_DIR"
  cp "$binary_path" "${INSTALL_DIR}/rin"
  chmod 755 "${INSTALL_DIR}/rin"

  if [[ ":$PATH:" == *":$HOME/.local/bin:"* ]]; then
    mkdir -p "$HOME/.local/bin"
    ln -sf "$INSTALL_DIR/rin" "$HOME/.local/bin/rin"
  fi

  info "Binary installed: ${INSTALL_DIR}/rin"
}

# ──────────────────────────────────────────────
# PATH SETUP
# ──────────────────────────────────────────────

setup_path() {
  $no_modify_path && return
  if [[ ":$PATH:" == *":$INSTALL_DIR:"* ]]; then
    muted "  ${INSTALL_DIR} already in PATH"
    return
  fi

  local current_shell
  current_shell=$(basename "${SHELL:-bash}")

  local config_files=()
  case "$current_shell" in
    fish) config_files=("$HOME/.config/fish/config.fish") ;;
    zsh)  config_files=("${ZDOTDIR:-$HOME}/.zshrc" "${ZDOTDIR:-$HOME}/.zshenv" "${XDG_CONFIG_HOME}/zsh/.zshrc") ;;
    bash) config_files=("$HOME/.bashrc" "$HOME/.bash_profile" "$HOME/.profile" "${XDG_CONFIG_HOME}/bash/.bashrc") ;;
    ash|sh) config_files=("$HOME/.ashrc" "$HOME/.profile") ;;
    *)    config_files=("$HOME/.bashrc" "$HOME/.bash_profile") ;;
  esac

  local target_file=""
  for f in "${config_files[@]}"; do
    [[ -f "$f" ]] && { target_file="$f"; break; }
  done

  if [[ -z "$target_file" ]]; then
    warn "No shell config file found. Add to PATH manually:"
    muted "  export PATH=\"${INSTALL_DIR}:\$PATH\""
    return
  fi

  local cmd="export PATH=\"${INSTALL_DIR}:\$PATH\""
  if grep -Fq "$INSTALL_DIR" "$target_file" 2>/dev/null; then
    muted "  Already in ${target_file}, skipping"
  elif [[ -w "$target_file" ]]; then
    echo "" >> "$target_file"
    echo "# RIN" >> "$target_file"
    echo "$cmd" >> "$target_file"
    info "Added to \$PATH in ${target_file}"
  else
    warn "Cannot write to ${target_file}"
    muted "  Manual addition: ${cmd}"
  fi

  if [[ -n "${GITHUB_ACTIONS-}" && "${GITHUB_ACTIONS}" == "true" ]]; then
    echo "$INSTALL_DIR" >> "$GITHUB_PATH"
    info "Added to \$GITHUB_PATH"
  fi
}

